# =========================
# Root .gitignore for MERN Project
# Folders: frontend / backend
# =========================

# -------------------------
# Dependencies
# -------------------------
frontend/node_modules/
backend/node_modules/

# -------------------------
# Environment Variables
# -------------------------
frontend/.env
backend/.env

# -------------------------
# Logs
# -------------------------
frontend/*.log
backend/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -------------------------
# Build Files
# -------------------------
frontend/build/
frontend/dist/
backend/build/
backend/dist/

# -------------------------
# Vercel / Deployment
# -------------------------
.vercel/

# -------------------------
# IDE Files
# -------------------------
.vscode/
.idea/

# -------------------------
# OS Files
# -------------------------
.DS_Store
Thumbs.db

# -------------------------
# Coverage
# -------------------------
frontend/coverage/
backend/coverage/

# -------------------------
# Temporary Files
# -------------------------
tmp/
temp/